						<!-- Play Time Slider -->
					<!--
						<slider-setting
								text="Play Time (minutes)"
								value="playTime"
								min="5"
								max="120"
								increment="1"
								apply-on-change="true" />
					</horizontal>
					<horizontal horizontal-fit="PreferredSize" spacing="3" >
						<toggle-setting text="Enable song requests (!sr / !bsr)"
										value="songRequestsEnabled"
										apply-on-change="true" />
